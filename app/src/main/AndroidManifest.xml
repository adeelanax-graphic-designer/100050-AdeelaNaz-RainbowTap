<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.adeelanaz.rainbowtap">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_college_monogram"
        android:label="RainbowTap"
        android:roundIcon="@mipmap/ic_college_monogram"
        android:supportsRtl="true"
        android:theme="@style/Theme.RainbowTap">

        <!-- THIS WAS THE MISSING PART -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Feature Activities -->
        <activity
            android:name=".TapGameActivity"
            android:exported="false" />

        <activity
            android:name=".ColorMixerActivity"
            android:exported="false" />

        <activity
            android:name=".RhythmGameActivity"
            android:exported="false" />

        <activity
            android:name=".ProfileActivity"
            android:exported="false" />

        <activity
            android:name=".QuotesActivity"
            android:exported="false" />

        <activity
            android:name=".QuoteClipboardActivity"
            android:exported="false" />

    </application>

</manifest>